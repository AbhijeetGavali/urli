{
  "manifest_version": 3,
  "name": "Urli for Etsy Sellers",
  "version": "1.0.0",
  "description": "Track which platform drives your Etsy sales. Shorten listing URLs with UTM tracking.",
  "permissions": ["activeTab", "storage", "clipboardWrite"],
  "host_permissions": ["https://www.etsy.com/*"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": { "48": "icons/icon48.png" }
  },
  "content_scripts": [{
    "matches": ["https://www.etsy.com/listing/*"],
    "js": ["src/content/etsy.ts"]
  }],
  "icons": { "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
